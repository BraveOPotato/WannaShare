# ---------------------------------------------------------------------------
# WannaSend frontend configuration
#
# Copy to `.env` (or set these in the Cloudflare Pages dashboard) and point
# them at the machine running the backend Docker services (see /backend).
#
# The frontend is a static site — deploy the `dist/` output to Cloudflare
# Pages. Only the coordination/PeerServer + coturn run in Docker on a host
# with a public IP.
# ---------------------------------------------------------------------------

# Coordination server (PeerJS PeerServer + presence WebSocket).
# Host/port/path of the PeerServer broker used by peerjs.
VITE_PEER_HOST=localhost
VITE_PEER_PORT=9000
VITE_PEER_PATH=/peerjs
# "true" when served over HTTPS/WSS (required in production & on Cloudflare Pages).
VITE_PEER_SECURE=false

# Presence / short-code WebSocket endpoint. Same backend process, but a
# SEPARATE port from the PeerServer above (9000 = broker, 9001 = presence).
# Use wss:// in production. Behind a reverse proxy you can route both under
# one hostname (e.g. wss://api.example.com/ws) — adjust accordingly.
VITE_SIGNALING_URL=ws://localhost:9001/ws

# Default ICE servers. Users can override these in-app (saved to localStorage);
# these are only the fallback defaults.
VITE_STUN_URLS=stun:localhost:3478
VITE_TURN_URLS=turn:localhost:3478
VITE_TURN_USERNAME=wannasend
VITE_TURN_CREDENTIAL=change-me-turn-secret

# Public URL of the deployed frontend, embedded in QR codes so a phone camera
# can deep-link straight into a connection. Defaults to window.location.origin.
VITE_PUBLIC_APP_URL=
